{
  "name": "ai-studio",
  "version": "0.1.0",
  "private": true,
  "description": "A powerful AI desktop client supporting multiple LLM providers",
  "main": "./out/main/index.js",
  "author": "support@ai-studio.com",
  "homepage": "https://github.com/ai-studio/ai-studio",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:win": "npm run build && electron-builder --win --x64 --arm64",
    "build:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "build:linux": "npm run build && electron-builder --linux --x64 --arm64",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.41.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@radix-ui/react-context-menu": "^2.2.0",
    "@reduxjs/toolkit": "^2.2.0",
    "ai": "^4.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.0",
    "i18next": "^23.11.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.344.0",
    "openai": "^4.70.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^14.1.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.0",
    "redux-persist": "^6.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^1.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "antd": "^5.16.0",
    "autoprefixer": "^10.4.24",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.1.0",
    "eslint": "^8.57.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
